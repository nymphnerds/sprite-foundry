{
  "manifest_version": 1,
  "id": "sprite-foundry",
  "name": "Sprite Foundry",
  "short_name": "SF",
  "version": "1.2.4",
  "description": "Foundry-native 8-direction sprite generation, review, lifecycle, and export pipeline for NymphsCore.",
  "category": "image",
  "kind": "sprite-foundry",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/sprite-foundry.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/sprite-foundry.git",
    "ref": "main"
  },
  "install": {
    "root": "$HOME/Sprite-Foundry",
    "entrypoint": "scripts/install_sprite_foundry.sh",
    "version_marker": "$HOME/Sprite-Foundry/.nymph-module-version",
    "installed_markers": [
      "$HOME/Sprite-Foundry/.nymph-module-version"
    ]
  },
  "runtime": {
    "host": "127.0.0.1",
    "port": 7001,
    "health_url": "http://127.0.0.1:7001/health",
    "server_info_url": "http://127.0.0.1:7001/server_info",
    "frontend_url": "http://127.0.0.1:7001/nymph"
  },
  "artifacts": {
    "outputs_root": "$HOME/NymphsData/outputs/sprite-foundry",
    "config_root": "$HOME/NymphsData/config/sprite-foundry",
    "logs_root": "$HOME/NymphsData/logs/sprite-foundry",
    "foundry_bakeoff_root": "$HOME/Sprite-Foundry/bakeoff",
    "foundry_exports_root": "$HOME/Sprite-Foundry/exports",
    "lora_root": "$HOME/LoRA/loras",
    "zimage_url": "http://127.0.0.1:8090"
  },
  "entrypoints": {
    "install": "scripts/install_sprite_foundry.sh",
    "update": "scripts/sprite_foundry_update.sh",
    "status": "scripts/sprite_foundry_status.sh",
    "open_nymph_ui": "scripts/sprite_foundry_open_ui.sh",
    "stop": "scripts/sprite_foundry_stop_ui.sh",
    "stop_ui": "scripts/sprite_foundry_stop_ui.sh",
    "foundry_cli": "scripts/sprite_foundry_cli.sh",
    "foundry_status": "scripts/sprite_foundry_foundry_status.sh",
    "foundry_generate": "scripts/sprite_foundry_generate.sh",
    "fetch_controlnet": "scripts/sprite_foundry_fetch_controlnet.sh",
    "delete_models": "scripts/sprite_foundry_delete_models.sh",
    "open_outputs": "scripts/sprite_foundry_open_outputs.sh",
    "logs": "scripts/sprite_foundry_logs.sh"
  },
  "capabilities": [
    "install",
    "status",
    "open_nymph_ui",
    "stop",
    "stop_ui",
    "foundry_cli",
    "foundry_status",
    "foundry_generate",
    "fetch_controlnet",
    "delete_models",
    "open_outputs",
    "logs"
  ],
  "ui": {
    "sort_order": 25,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_url",
      "title": "Sprite Foundry",
      "entrypoint": "open_nymph_ui",
      "url": "http://127.0.0.1:7001/nymph",
      "health_url": "http://127.0.0.1:7001/health",
      "requires_running": true,
      "start_action": "open_nymph_ui",
      "stop_action": "stop"
    },
    "manager_action_groups": [
      {
        "id": "model_fetch",
        "title": "Model Fetch",
        "layout": "compact",
        "entrypoint": "fetch_controlnet",
        "result": "show_logs",
        "visibility": "installed",
        "description": "Download the shared backend weights and pixel-art LoRAs required by Sprite Foundry. Z-Image backend weights use the shared Hugging Face cache; LoRAs are written to the shared LoRA folder used by the LoRA module and Z-Image.",
        "links": [
          {
            "label": "ControlNet weight",
            "url": "https://huggingface.co/alibaba-pai/Z-Image-Turbo-Fun-Controlnet-Union-2.1"
          },
          {
            "label": "Nymphs Image backend",
            "url": "https://github.com/nymphnerds/zimage"
          }
        ],
        "fields": [
          {
            "name": "controlnet_profile",
            "type": "select",
            "label": "Download",
            "arg": "--model",
            "default": "sprite_foundry_starter_stack",
            "options": [
              {
                "label": "Complete Sprite Foundry Starter Stack",
                "value": "sprite_foundry_starter_stack",
                "description": "Fetch Z-Image INT4 r32, ControlNet 2.1, and the recommended Z-Image Turbo Pixel LoRA"
              },
              {
                "label": "Z-Image ControlNet 2.1",
                "value": "sprite_foundry_controlnet_2_1",
                "description": "Required by Sprite Foundry direction control"
              },
              {
                "label": "All Sprite Foundry LoRAs",
                "value": "sprite_foundry_all_loras",
                "description": "Fetch all bundled Z-Image pixel-art LoRA choices into the shared LoRA folder"
              },
              {
                "label": "Z-Image Turbo Pixel LoRA",
                "value": "sprite_foundry_lora_mks0813_pixel_art",
                "description": "Recommended first Sprite Foundry LoRA; trigger: pxlstl"
              },
              {
                "label": "Pixel-artist-Z Character LoRA",
                "value": "sprite_foundry_lora_skyasl_pixel_artist",
                "description": "Alternative character pixel-art LoRA"
              },
              {
                "label": "Pixel Art Style LoRA",
                "value": "sprite_foundry_lora_tarn59_pixel_art",
                "description": "Alternative pixel-art style LoRA"
              }
            ]
          },
          {
            "name": "hf_token",
            "type": "secret",
            "label": "Hugging Face token",
            "secret_id": "huggingface.token",
            "env": "NYMPHS3D_HF_TOKEN",
            "optional": true
          }
        ],
        "submit": {
          "label": "Fetch ControlNet"
        }
      }
    ],
    "manager_actions": [
      {
        "id": "open_nymph_ui",
        "label": "Open UI",
        "entrypoint": "open_nymph_ui",
        "result": "open_in_manager",
        "visibility": "installed"
      },
      {
        "id": "open_outputs",
        "label": "Open Outputs",
        "entrypoint": "open_outputs",
        "result": "open_directory",
        "visibility": "installed"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "open_notepad",
        "visibility": "installed"
      }
    ]
  },
  "requirements": {
    "wsl": true,
    "python": ">=3.11",
    "gpu": "NVIDIA CUDA recommended",
    "dependencies": [
      "Z-Image module for NymphsCore generation backend",
      "Nunchaku runtime for accelerated Z-Image generation",
      "A Z-Image-compatible sprite/pixel-art LoRA"
    ]
  },
  "notes": {
    "workflow": "Sprite Foundry owns the Foundry run/review/export lifecycle. Z-Image is a backend, not the user-facing workflow."
  }
}
