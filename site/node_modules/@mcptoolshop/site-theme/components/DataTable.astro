---
interface Props {
  columns: string[];
  rows: string[][];
}

const { columns, rows } = Astro.props;
---

<div class="mt-8 overflow-hidden rounded-2xl border border-edge-subtle">
  <table class="w-full text-xs text-dim">
    <thead>
      <tr>
        {columns.map((col: string) => (
          <th scope="col" class="border-b border-edge-subtle bg-surface p-4 text-left font-semibold">{col}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row: string[]) => (
        <tr>
          {row.map((cell: string, i: number) => (
            <td class={`border-b border-edge-subtle bg-surface p-4${i === 0 ? ' font-medium text-body' : ''}`}>{cell}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
