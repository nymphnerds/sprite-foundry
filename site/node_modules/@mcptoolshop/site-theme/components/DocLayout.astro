---
import Sidebar from './Sidebar.astro';

interface Props {
  sidebar: { title: string; items: { label: string; href: string }[] }[];
  currentPath: string;
}

const { sidebar, currentPath } = Astro.props;
---

<div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-8">
  <!-- Mobile sidebar toggle -->
  <details class="mb-6 rounded-xl border border-edge bg-surface-raised lg:hidden">
    <summary aria-label="Toggle navigation menu" class="cursor-pointer px-4 py-3 text-sm font-medium text-body">
      Navigation
    </summary>
    <div class="border-t border-edge px-4 py-3">
      <Sidebar groups={sidebar} currentPath={currentPath} />
    </div>
  </details>

  <!-- Desktop sidebar -->
  <aside class="hidden lg:block">
    <div class="sticky top-6 max-h-[calc(100vh-3rem)] overflow-y-auto">
      <Sidebar groups={sidebar} currentPath={currentPath} />
    </div>
  </aside>

  <!-- Main content -->
  <div class="min-w-0">
    <slot />
  </div>
</div>
