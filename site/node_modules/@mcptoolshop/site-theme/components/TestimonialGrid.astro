---
interface Props {
  testimonials?: {
    quote: string;
    author: string;
    role: string;
    avatarUrl?: string;
  }[];
}

const { testimonials = [] } = Astro.props;
---

<div class="mt-8 grid gap-6 md:grid-cols-2">
  {testimonials.map((t: {
    quote: string;
    author: string;
    role: string;
    avatarUrl?: string;
  }) => (
    <div class="rounded-2xl border border-edge-subtle bg-surface p-6">
      <blockquote class="text-body italic leading-relaxed">
        &ldquo;{t.quote}&rdquo;
      </blockquote>
      <div class="mt-4 flex items-center gap-3">
        {t.avatarUrl ? (
          <img
            src={t.avatarUrl}
            alt={t.author}
            class="h-10 w-10 rounded-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-surface-strong text-sm font-semibold text-heading">
            {t.author.split(' ').map((w) => w[0]).join('').slice(0, 2)}
          </div>
        )}
        <div>
          <p class="text-sm font-semibold text-heading">{t.author}</p>
          <p class="text-xs text-dim">{t.role}</p>
        </div>
      </div>
    </div>
  ))}
</div>
