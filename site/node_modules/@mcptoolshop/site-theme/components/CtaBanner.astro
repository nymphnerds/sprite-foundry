---
interface Props {
  headline: string;
  description?: string;
  cta: { href: string; label: string };
}

const { headline, description, cta } = Astro.props;
---

<section class="mt-16 overflow-hidden rounded-3xl border border-edge bg-gradient-to-b from-surface-raised/60 to-surface px-6 py-16 text-center md:px-12">
  <div class="absolute inset-0 opacity-30 [background:radial-gradient(600px_circle_at_50%_50%,rgba(255,255,255,0.08),transparent_60%)]"></div>
  <div class="relative">
    <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">
      {headline}
    </h2>
    {description && (
      <p class="mx-auto mt-4 max-w-xl text-lg text-muted">{description}</p>
    )}
    <div class="mt-8">
      <a
        href={cta.href}
        class="inline-flex items-center justify-center rounded-xl bg-action px-6 py-3 text-sm font-medium text-action-text hover:bg-action-hover"
      >
        {cta.label}
      </a>
    </div>
  </div>
</section>
