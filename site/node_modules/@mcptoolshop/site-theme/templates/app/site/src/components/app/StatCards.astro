---
interface Stat {
  label: string;
  value: string;
  change?: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  {stats.map((stat) => (
    <div class="bg-surface-raised border border-edge rounded-lg p-4">
      <p class="text-sm text-dim">{stat.label}</p>
      <p class="text-2xl font-bold text-heading mt-1">{stat.value}</p>
      {stat.change && (
        <p class:list={[
          'text-xs mt-1',
          stat.change.startsWith('+') ? 'text-accent' : 'text-dim',
        ]}>
          {stat.change}
        </p>
      )}
    </div>
  ))}
</div>
