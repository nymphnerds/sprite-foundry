---
interface Props {
  icon?: string;
  title: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { icon = '◻', title, description, ctaLabel, ctaHref } = Astro.props;
---

<div class="flex flex-col items-center justify-center py-16 text-center">
  <span class="text-4xl text-dim mb-4">{icon}</span>
  <h3 class="text-lg font-medium text-heading mb-1">{title}</h3>
  {description && <p class="text-sm text-dim max-w-sm">{description}</p>}
  {ctaLabel && ctaHref && (
    <a
      href={ctaHref}
      class="mt-4 inline-flex items-center px-4 py-2 bg-action text-action-text text-sm font-medium rounded-md hover:bg-action-hover transition-colors"
    >
      {ctaLabel}
    </a>
  )}
</div>
