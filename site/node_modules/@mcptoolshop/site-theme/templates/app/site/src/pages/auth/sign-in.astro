---
import AuthLayout from '../../layouts/AuthLayout.astro';
import FormField from '../../components/app/FormField.astro';

const base = import.meta.env.BASE_URL;
---

<AuthLayout title="Sign in">
  <h2 class="text-xl font-bold text-heading mb-1">Welcome back</h2>
  <p class="text-sm text-dim mb-6">Sign in to your account to continue.</p>

  <form id="sign-in-form">
    <FormField label="Email" name="email" type="email" placeholder="you@example.com" required />
    <FormField label="Password" name="password" type="password" placeholder="••••••••" required />

    <div class="flex items-center justify-between mb-4">
      <label class="flex items-center gap-2 text-sm text-body">
        <input type="checkbox" class="accent-accent" />
        Remember me
      </label>
      <a href={`${base}auth/forgot-password`} class="text-sm text-accent hover:underline">
        Forgot password?
      </a>
    </div>

    <button
      type="submit"
      class="w-full bg-action text-action-text font-medium py-2 px-4 rounded-md hover:bg-action-hover transition-colors text-sm"
    >
      Sign in
    </button>
  </form>

  <p class="mt-4 text-center text-sm text-dim">
    Don't have an account?
    <a href={`${base}auth/sign-up`} class="text-accent hover:underline">Sign up</a>
  </p>
</AuthLayout>

<script>
  import { signIn } from '../../lib/auth';
  import { getDefaultWorkspace } from '../../lib/workspaces';

  document.getElementById('sign-in-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    signIn();
    const params = new URLSearchParams(window.location.search);
    const next = params.get('next') || `${import.meta.env.BASE_URL}app/${getDefaultWorkspace().slug}/`;
    window.location.replace(next);
  });
</script>
