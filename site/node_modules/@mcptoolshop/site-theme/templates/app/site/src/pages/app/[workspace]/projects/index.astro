---
import AppShell from '../../../../layouts/AppShell.astro';
import DataTable from '../../../../components/app/DataTable.astro';
import { getWorkspaceSlugs } from '../../../../lib/workspaces';
import { listProjects } from '../../../../data';

export function getStaticPaths() {
  return getWorkspaceSlugs().map((workspace) => ({ params: { workspace } }));
}

const { workspace } = Astro.params;
const projects = listProjects(workspace!);

const columns = [
  { key: 'name', label: 'Name' },
  { key: 'status', label: 'Status' },
  { key: 'updated', label: 'Last Updated', align: 'right' as const },
];

const rows = projects.map((p) => ({
  name: p.name,
  status: p.status,
  updated: p.updated,
}));
---

<AppShell title="Projects" activeNav="projects" workspace={workspace!}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-heading">Projects</h1>
    <button class="inline-flex items-center px-4 py-2 bg-action text-action-text text-sm font-medium rounded-md hover:bg-action-hover transition-colors">
      New project
    </button>
  </div>
  <DataTable columns={columns} rows={rows} emptyMessage="No projects yet. Create your first project to get started." />
</AppShell>
