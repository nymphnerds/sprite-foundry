---
import '../styles/global.css';
import { siteConfig } from '../config/site.config';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="bg-surface text-body">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {siteConfig.brand}</title>
  </head>
  <body class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <a href={base} class="inline-flex items-center gap-2 text-heading font-bold text-xl hover:text-accent transition-colors">
          {siteConfig.brand}
        </a>
      </div>
      <div class="bg-surface-raised border border-edge rounded-lg p-6">
        <slot />
      </div>
    </div>
  </body>
</html>
