---
interface Props {
  message?: string;
  backHref?: string;
  backLabel?: string;
}

const {
  message = 'You do not have permission to view this page.',
  backHref,
  backLabel = 'Go to Dashboard',
} = Astro.props;
---

<div class="flex flex-col items-center justify-center py-20 text-center">
  <span class="text-5xl text-dim mb-4">&#128274;</span>
  <h2 class="text-xl font-bold text-heading mb-2">Access Denied</h2>
  <p class="text-sm text-dim max-w-md mb-6">{message}</p>
  {backHref && (
    <a
      href={backHref}
      class="inline-flex items-center px-4 py-2 bg-action text-action-text text-sm font-medium rounded-md hover:bg-action-hover transition-colors"
    >
      {backLabel}
    </a>
  )}
</div>
