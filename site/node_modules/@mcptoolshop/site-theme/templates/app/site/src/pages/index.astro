---
/**
 * Root redirect — sends to default workspace if authenticated, sign-in otherwise.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
  </head>
  <body>
    <script>
      import { isAuthenticated } from '../lib/auth';
      import { getDefaultWorkspace } from '../lib/workspaces';
      const base = import.meta.env.BASE_URL;
      const ws = getDefaultWorkspace().slug;
      window.location.replace(isAuthenticated() ? `${base}app/${ws}/` : `${base}auth/sign-in`);
    </script>
  </body>
</html>
