{
  "name": "@mcptoolshop/site-theme",
  "version": "1.5.0",
  "type": "module",
  "description": "Multi-template Astro toolkit for landing pages, docs, product sites, portfolios, and SaaS dashboards",
  "keywords": [
    "astro-component",
    "withastro",
    "theme",
    "mcp",
    "saas",
    "portfolio",
    "catalog",
    "scaffold",
    "multi-tenant",
    "rbac"
  ],
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/site-theme.git"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/site-theme/",
  "exports": {
    ".": "./types/config.ts",
    "./types/docs-config": "./types/docs-config.ts",
    "./types/portfolio-config": "./types/portfolio-config.ts",
    "./types/product-config": "./types/product-config.ts",
    "./styles/theme.css": "./styles/theme.css",
    "./components/BaseLayout.astro": "./components/BaseLayout.astro",
    "./components/Hero.astro": "./components/Hero.astro",
    "./components/Section.astro": "./components/Section.astro",
    "./components/FeatureGrid.astro": "./components/FeatureGrid.astro",
    "./components/DataTable.astro": "./components/DataTable.astro",
    "./components/CodeCardGrid.astro": "./components/CodeCardGrid.astro",
    "./components/ApiList.astro": "./components/ApiList.astro",
    "./components/DocLayout.astro": "./components/DocLayout.astro",
    "./components/Sidebar.astro": "./components/Sidebar.astro",
    "./components/TableOfContents.astro": "./components/TableOfContents.astro",
    "./components/ContentSection.astro": "./components/ContentSection.astro",
    "./components/SocialProof.astro": "./components/SocialProof.astro",
    "./components/PricingGrid.astro": "./components/PricingGrid.astro",
    "./components/TestimonialGrid.astro": "./components/TestimonialGrid.astro",
    "./components/CtaBanner.astro": "./components/CtaBanner.astro",
    "./components/PortfolioGrid.astro": "./components/PortfolioGrid.astro",
    "./components/FilterBar.astro": "./components/FilterBar.astro"
  },
  "files": [
    "components",
    "styles",
    "types",
    "templates",
    "cli",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "site-theme": "./cli/init.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "@tailwindcss/vite": ">=4.0.0",
    "astro": ">=5.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
